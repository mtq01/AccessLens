{
  "name": "accesslens-extension",
  "version": "0.1.0",
  "description": "Developer-first accessibility inspector",
  "scripts": {
    "dev": "webpack --watch --mode development",
    "build": "webpack --mode production",
    "css:prune": "node scripts/prune-panel-css.mjs",
    "css:shrink": "node scripts/shrink-panel-css.mjs",
    "css:build": "npm run css:prune && npm run css:shrink"
  },
  "dependencies": {
    "axe-core": "^4.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "csso": "^5.0.5",
    "postcss": "^8.5.12",
    "style-loader": "^3.3.3",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4"
  }
}
